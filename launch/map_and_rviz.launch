<?xml version="1.0" encoding="utf-8"?>
<launch>
    <node name="rviz" pkg="rviz" type="rviz" output="screen"
        args="-d $(find polys_mapgen)/rviz/view_map.rviz"> 
    </node>

    <node pkg="polys_mapgen" type="hpolys_mapgen_node" name="hpolys_mapgen_node" output="screen">
        <rosparam file="$(find polys_mapgen)/cfg/mapgen.yaml" command="load" />
        <remap from="/polys_pc_map" to="/voxel_map"/>
    </node>
</launch>